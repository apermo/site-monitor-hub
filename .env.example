DATABASE_PATH=./data/monitor.sqlite
STALE_THRESHOLD_HOURS=48

# ALLOW_HTTP=true  # Uncomment for local development only

# Only accept reports from these environment types (comma-separated).
# Leave empty or unset to accept all. WP types: production, staging, development, local
# ACCEPTED_ENVIRONMENTS=production,staging

# Vulnerability providers (comma-separated: wordfence, wpscan)
# VULN_PROVIDERS=wordfence,wpscan
# WORDFENCE_API_KEY=your-api-key-here
# WPSCAN_API_KEY=your-api-key-here
# WPSCAN_SYNC_HOURS=24
# WPSCAN_SLUG_INCLUDE=                 # Regex: only check matching slugs
# WPSCAN_SLUG_EXCLUDE=my-company-.*    # Regex: skip matching slugs
